# Blotato API key — get from https://app.blotato.com/settings/api
BLOTATO_API_KEY=your_blotato_api_key_here

# Google Gemini API key — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Perplexity API key — get from https://www.perplexity.ai/settings/api
# Required only for --perplexity mode (no YouTube URL needed)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Imagen Model Configuration (Optional, default: imagen-4.0-generate-001)
IMAGEN_MODEL=imagen-4.0-generate-001

# Notifications (Optional)
# Get Discord URL from Channel Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=
# For Gmail, use an "App Password" (https://myaccount.google.com/apppasswords)
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
